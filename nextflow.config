params {
    // ---- Input / Output ------------------------------------------------
    feature_table        = null               // required
    meta_table           = null               // required
    taxonomy_table       = ""                 // required if input_format != biom
    tree_file            = ""                 // required for FaithsPD metric
    input_format         = "biom"             // biom | tsv | gtdb
    output_dir           = "${projectDir}/results"

    // ---- Filtering ------------------------------------------------------
    min_library_size     = 5000
    exclude_column       = ""
    exclude_values       = ""

    // ---- Grouping -------------------------------------------------------
    group                = ""   // one column, or comma-separated columns to paste
    type                 = ""   // one column, or comma-separated columns (optional)

    // ---- Alpha diversity ------------------------------------------------
    taxon_rank           = "Feature"
    label                = "analysis"
    normalization        = "clr"              // clr | rarefaction
    alpha_metrics        = "Richness,Shannon,GiniSimpson,FisherAlpha,PielouEvenness"
    test_method          = "anova"            // anova | kruskal | none | auto
    p_adjust_method      = "BH"               // BH | bonferroni | holm | fdr | none

    // ---- Output options -------------------------------------------------
    merge_parquet        = false
    sensitivity_analysis = false
    sensitivity_depths   = "0.5,0.75,1.0"    // fractions of min_library_size
                                               // (ignored unless normalization=rarefaction)
}

// ---- Built-in run reporting -------------------------------------------
// These write HTML/TXT reports alongside results; disable via -with-report false
report {
    enabled = true
    file    = "${params.output_dir}/pipeline_report.html"
}
trace {
    enabled = true
    file    = "${params.output_dir}/pipeline_trace.txt"
}
timeline {
    enabled = true
    file    = "${params.output_dir}/pipeline_timeline.html"
}

// ---- Default: conda ---------------------------------------------------
conda.enabled = true

process {
    conda = "${projectDir}/environment.yml"
}

profiles {
    conda {
        conda.enabled  = true
        docker.enabled = false
    }
    docker {
        conda.enabled     = false
        docker.enabled    = true
        docker.runOptions = "-u \$(id -u):\$(id -g) -v ${projectDir}:${projectDir}:ro"
        process {
            container = 'reubenduncan/ecologyflow-alpha:latest'
        }
    }
    singularity {
        conda.enabled          = false
        singularity.enabled    = true
        singularity.autoMounts = true
        process {
            container = 'docker://reubenduncan/ecologyflow-alpha:latest'
        }
    }
}

manifest {
    name            = 'alpha-diversity'
    description     = 'Alpha diversity analysis pipeline for microbiome compositional data'
    author          = 'Reuben Duncan'
    version         = '1.0.0'
    nextflowVersion = '>=23.04'
}
