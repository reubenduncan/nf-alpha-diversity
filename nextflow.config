params {
    // ---- Input / Output ------------------------------------------------
    feature_table        = "${projectDir}/data/feature_table.biom"
    meta_table           = "${projectDir}/data/meta_table.csv"
    taxonomy_table       = ""                   // required if input_format != biom
    tree_file            = ""                   // optional; accepted but not used
    input_format         = "biom"               // biom | tsv | gtdb
    output_dir           = "${projectDir}/results"

    // ---- Filtering ------------------------------------------------------
    min_library_size     = 5000
    exclude_column       = ""
    exclude_values       = ""

    // ---- Grouping -------------------------------------------------------
    group                = ""   // one column, or comma-separated columns to paste as group label
    type                 = ""   // one column, or comma-separated columns to paste as point-style label (optional)

    // ---- Alpha diversity ------------------------------------------------
    which_level          = "Phylum"
    label                = "analysis"
    alpha_metrics        = "Richness,Shannon,Simpson,FisherAlpha,PielouEvenness"
    test_method          = "anova"              // anova | kruskal | none
    p_adjust_method      = "BH"                 // BH | bonferroni | holm | fdr | none

    // ---- Output options -------------------------------------------------
    merge_parquet        = false
}

// ---- Default: conda -------------------------------------------------
conda.enabled = true

process {
    conda = "${projectDir}/environment.yml"
}

profiles {
    conda {
        conda.enabled  = true
        docker.enabled = false
    }
    docker {
        conda.enabled     = false
        docker.enabled    = true
        docker.runOptions = "-u \$(id -u):\$(id -g) -v ${projectDir}:${projectDir}:ro"
        process {
            container = 'reubenduncan/ecologyflow-alpha:latest'
        }
    }
    singularity {
        conda.enabled          = false
        singularity.enabled    = true
        singularity.autoMounts = true
        process {
            container = 'docker://reubenduncan/ecologyflow-alpha:latest'
        }
    }
}

manifest {
    name        = 'alpha-diversity'
    description = 'Alpha diversity analysis pipeline for microbiome data'
    version     = '1.0.0'
    nextflowVersion = '>=23.04'
}
