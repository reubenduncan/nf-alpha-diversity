params {
    // ---- Input / Output ------------------------------------------------
    feature_table        = "${projectDir}/data/feature_table.biom"
    meta_table           = "${projectDir}/data/meta_table.csv"
    taxonomy_table       = ""                   // required if input_format != biom
    tree_file            = ""                   // optional; accepted but not used
    input_format         = "biom"               // biom | tsv | gtdb
    output_dir           = "${projectDir}/results"
    scripts_dir          = "/opt/ecology-scripts"

    // ---- Filtering ------------------------------------------------------
    min_library_size     = 5000
    exclude_column       = ""
    exclude_values       = ""

    // ---- Grouping -------------------------------------------------------
    groups_column        = ""
    groups_paste_columns = ""
    type_column          = ""
    type2_column         = ""
    type2_levels         = ""
    connections_column   = ""

    // ---- Alpha diversity ------------------------------------------------
    which_level          = "Phylum"
    label                = "analysis"
    alpha_metrics        = "Richness,Shannon,Simpson,FisherAlpha,PielouEvenness"
    test_method          = "anova"              // anova | kruskal | none
    p_adjust_method      = "BH"                 // BH | bonferroni | holm | fdr | none

    // ---- Output options -------------------------------------------------
    merge_parquet        = false
}

docker {
    enabled    = true
    runOptions = '-u $(id -u):$(id -g)'
}

process {
    container = 'reubenduncan/ecologyflow-alpha:latest'
}

manifest {
    name        = 'alpha-diversity'
    description = 'Alpha diversity analysis pipeline for microbiome data'
    version     = '1.0.0'
    nextflowVersion = '>=23.04'
}
